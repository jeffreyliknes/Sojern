---
interface Props {
  title: string;
  text: string;
  href?: string;
  image?: string;
  kicker?: string;
}

const { title, text, href, image, kicker } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="feature-card panel" href={href}>
  {image && (
    <div class="image-wrap">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    {kicker && <p class="eyebrow">{kicker}</p>}
    <h3>{title}</h3>
    <p>{text}</p>
    {href && <span class="link-arrow">Mehr erfahren</span>}
  </div>
</Tag>

<style>
  .feature-card {
    display: grid;
    min-height: 100%;
    overflow: hidden;
    color: inherit;
    transition:
      transform 220ms ease,
      border-color 220ms ease;
  }

  .feature-card:hover {
    transform: translateY(-6px);
    border-color: rgba(225, 193, 111, 0.55);
  }

  .image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 650ms ease;
  }

  .feature-card:hover img {
    transform: scale(1.045);
  }

  .card-body {
    display: grid;
    gap: 0.7rem;
    padding: 1.4rem;
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    line-height: 1;
  }

  p {
    margin: 0;
    color: var(--muted);
  }
</style>

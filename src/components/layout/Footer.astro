---
import { navigation, routes, site } from "@/data/site";
---

<footer class="site-footer">
  <div class="footer-statement">
    <div class="container">
      <p class="footer-claim">Hotel mit Handschrift</p>
    </div>
  </div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/images/brand/logo.svg" alt={site.name} class="footer-logo" />
      <address>
        <p>{site.address[0]}</p>
        <p>{site.address[1]}</p>
        <p class="footer-contact">
          <a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>
        </p>
        <p class="footer-contact">
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </address>
    </div>

    <nav aria-label="Fußnavigation" class="footer-nav">
      <p class="footer-nav-label eyebrow">Navigation</p>
      {navigation.map((group) => (
        <a href={group.href}>{group.label}</a>
      ))}
      <a href={routes.contact}>Anfahrt & Kontakt</a>
    </nav>

    <div class="footer-cta">
      <p class="footer-nav-label eyebrow">Direkt planen</p>
      <a class="button" href={routes.booking}>Aufenthalt buchen</a>
      <a class="button secondary" href={routes.contact}>Kontakt aufnehmen</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {new Date().getFullYear()} {site.name}</p>
      <p>Quedlinburg · UNESCO Welterbestadt</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 8rem;
    border-top: 1px solid var(--line);
  }

  .footer-statement {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .footer-claim {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 9rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--umber-2);
    -webkit-text-stroke: 1px rgba(210, 170, 80, 0.25);
    text-stroke: 1px rgba(210, 170, 80, 0.25);
    margin: 0;
    white-space: nowrap;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.9fr 0.9fr;
    gap: 3rem;
    padding: 4rem 0;
    color: var(--soft);
    font-size: 0.95rem;
  }

  .footer-logo {
    width: 155px;
    margin-bottom: 1.75rem;
    filter: brightness(1.08) sepia(0.18);
  }

  address {
    font-style: normal;
    display: grid;
    gap: 0.25rem;
  }

  address p {
    margin: 0;
  }

  .footer-contact {
    margin-top: 0.5rem !important;
  }

  address a:hover,
  .footer-nav a:hover {
    color: var(--gold-bright);
  }

  .footer-nav-label {
    margin-bottom: 0.75rem;
  }

  .footer-nav,
  .footer-cta {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  .footer-nav a,
  address a {
    transition: color 140ms ease;
  }

  .footer-cta {
    gap: 0.75rem;
  }

  .footer-cta .button {
    width: fit-content;
    font-size: 0.78rem;
  }

  .footer-bottom {
    border-top: 1px solid var(--line);
    padding: 1.5rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--soft);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-claim {
      font-size: clamp(2.5rem, 10vw, 5rem);
      white-space: normal;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

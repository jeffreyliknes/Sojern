---
import Header from "@/components/navigation/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import "@/styles/global.css";
import { site } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.name,
  description = "Romantik Hotel am Brühl in Quedlinburg.",
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const widgetExclusionPrefixes = [
  "/agb",
  "/impressum",
  "/datenschutz",
  "/404",
  "/weinstube-am-bruehl",
  "/restaurant",
];
const showBookingWidget = !widgetExclusionPrefixes.some(
  (prefix) => pathname === prefix || pathname.startsWith(`${prefix}/`),
);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    {showBookingWidget && (
      <>
        <link
          rel="stylesheet"
          href="https://mws-booking-widget.ams3.cdn.digitaloceanspaces.com/mws-booking-widget-v1.min.css"
        />
        <script src="https://mws-booking-widget.ams3.cdn.digitaloceanspaces.com/mws-booking-widget-v1.min.js"></script>
      </>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    {showBookingWidget && <div id="booking-widget-container"></div>}
    <Footer />
    {showBookingWidget && (
      <script>
        const bookingWidgetConfig = {
          autoGenerateComponent: false,
          defaultLink: "https://onepagebooking.com/romantikhotel",
          deeplink: "https://r.myhotelshop.de/ibe.php",
          predefinedDeeplinkParameters: {
            hotelId: "12652",
            placement: "104",
            partnerId: "HotelNetSolutionsV5",
          },
          defaultLanguage: document.documentElement.lang === "en" ? "en" : "de",
          languageMapping: { en: "en", de: "de" },
          dateFormatToBeParsed: "DDMMYY",
          widthToChangeToButton: 900,
          topToChangeThePosition: 300,
          bookingButton: {
            header: {
              en: "Best-Price-Guarantee",
              de: "Best-Price-Garantie",
            },
            label: {
              booking: { en: "Book Now", de: "Jetzt buchen" },
              voucher: { en: "Check Now", de: "Check jetzt" },
              events: { en: "Check Events", de: "Events jetzt" },
            },
          },
          bookingTab: {
            id: "booking",
            label: { en: "Availability check", de: "Verfugbarkeit prufen" },
            form: [
              {
                name: "dateRange",
                type: "dateRangePicker",
                minBookableDays: 0,
                invalidDateRangeMessage: {
                  en: "Must be more than {minBookableDays} days",
                  de: "Muss langer als {minBookableDays} Tage sein",
                },
                placeholder: {
                  arrival: { en: "Arrival", de: "Anreise" },
                  departure: { en: "Departure", de: "Abreise" },
                },
                dateFormatToBeShown: { en: "DD/MM/YYYY", de: "DD.MM.YYYY" },
              },
              {
                name: "rooms",
                type: "roomSelect",
                maxRoom: 3,
                defaultValue: 0,
                placeholder: {
                  rooms: { en: "Rooms", de: "Zimmer" },
                  people: { en: "People", de: "Personen" },
                },
                fieldArray: {
                  title: { en: "Room", de: "Zimmer" },
                  adults: {
                    name: "adults",
                    label: { en: "Adults", de: "Erwachsene" },
                    defaultValue: 0,
                    min: 1,
                    max: 3,
                  },
                  children: {
                    name: "children",
                    label: { en: "Children", de: "Kinder" },
                    defaultValue: 0,
                    min: 0,
                    max: 3,
                  },
                  childrenAges: {
                    name: "childrenages",
                    label: { en: "Age", de: "Alter" },
                    defaultValue: 5,
                    min: 3,
                    max: 10,
                  },
                  addRoomLabel: { en: "Add Room", de: "Zimmer hinzufugen" },
                  removeRoomLabel: { en: "Remove", de: "Entfernen" },
                },
              },
            ],
          },
          optionalTabs: [],
        };

        document.addEventListener("DOMContentLoaded", () => {
          const widgetApi = (
            window as Window & { bookingWidget?: { init: (config: unknown) => void } }
          ).bookingWidget;
          if (!widgetApi) return;
          widgetApi.init(bookingWidgetConfig);
        });
      </script>
    )}
  </body>
</html>

<style is:global>
  #booking-widget-container {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
  }

  @media (max-width: 768px) {
    #booking-widget-container {
      bottom: 0;
      width: 100%;
      min-width: 100%;
    }
  }

  #booking-widget-container svg {
    fill: var(--gold);
  }

  #booking-widget-container .tab-button {
    background-color: var(--gold);
    color: var(--charcoal);
  }

  #booking-widget-container .tab-button.selected {
    background-color: var(--charcoal);
    color: var(--ink);
  }

  #booking-widget-container .booking-widget_tab-content,
  #booking-widget-container .booking-widget_generic-fields-list {
    background-color: var(--charcoal);
  }

  #booking-widget-container .booking-widget-date-picker,
  #booking-widget-container .booking-widget_room-select-list,
  #booking-widget-container .booking-widget_select-wrapper-options-list {
    background-color: var(--umber-2);
  }

  #booking-widget-container .booking-widget_select-wrapper-options-list li:hover {
    background-color: rgba(163, 128, 82, 0.22);
  }

  #booking-widget-container .DayPicker-Day:hover {
    background-color: var(--gold);
    color: var(--charcoal);
  }

  #booking-widget-container .DayPicker-Day.DayPicker-Day--selected {
    background-color: var(--gold);
    color: var(--charcoal);
  }

  #booking-widget-container .DayPicker-Day.DayPicker-Day--selected:not(.DayPicker-Day--start):not(.DayPicker-Day--end):not(.DayPicker-Day--outside) {
    background-color: rgba(163, 128, 82, 0.24) !important;
    color: var(--ink);
  }

  #booking-widget-container .booking-widget_mobile-button,
  #booking-widget-container .book-button {
    background-color: var(--gold);
    color: var(--charcoal);
    transition: background-color 180ms ease;
  }

  #booking-widget-container .booking-widget_mobile-button:hover,
  #booking-widget-container .book-button:hover {
    background-color: var(--gold-bright);
  }

  #booking-widget-container .booking-widget_mobile-button svg,
  #booking-widget-container .book-button svg {
    fill: var(--charcoal);
  }
</style>

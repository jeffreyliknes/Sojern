---
import BookingStrip from "@/components/sections/BookingStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import rooms from "@/data/rooms.json";

const klassikRooms = rooms.filter((room) => room.category === "Klassik");
const klassik = klassikRooms[0];
const amenities = klassik?.amenities ?? [];
---

<BaseLayout title="Klassik Zimmer" description={klassik?.description_de}>
  <section class="room-hero container">
    <div class="room-copy">
      <p class="eyebrow">Klassik Zimmer</p>
      <h1 class="display">Klassik Zimmer</h1>
      <p class="lede">{klassik?.description_de}</p>
      <div class="room-facts">
        {klassikRooms.map((room) => (
          <article>
            <span>{room.type}</span>
            <strong>{room.size_sqm} qm</strong>
          </article>
        ))}
      </div>
    </div>
    <div class="room-gallery">
      <img class="main-image" src="/images/rooms/klassik-1.jpg" alt="" />
      <img src="/images/rooms/klassik-2.jpg" alt="" />
    </div>
  </section>

  <BookingStrip />

  <section class="container details-grid">
    <article class="panel details-panel">
      <p class="eyebrow">Zimmerdetails</p>
      <h2>Ausstattung</h2>
      <ul class="amenities">
        {amenities.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <aside class="panel practical-panel">
      <p class="eyebrow">Zusätzliche Informationen</p>
      <ul>
        <li>Frühstücksbuffet inklusive</li>
        <li>Haustiere: 20 €/Tag</li>
        <li>24h-Rezeption</li>
        <li>Parken: 10 €/Nacht</li>
        <li>Sauna: 15 €/Person</li>
      </ul>
      <a class="button" href="/buchen">Buchen</a>
      {klassik?.tour_360_url && <a class="button secondary" href={klassik.tour_360_url}>360° Rundgang</a>}
    </aside>
  </section>
</BaseLayout>

<style>
  .room-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(360px, 1.22fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: end;
    padding: 5rem 0 4rem;
  }

  .room-copy {
    display: grid;
    gap: 1rem;
  }

  .room-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .room-facts article {
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: rgba(42, 27, 19, 0.65);
  }

  .room-facts span,
  .room-facts strong {
    display: block;
  }

  .room-facts span {
    color: var(--muted);
  }

  .room-facts strong {
    color: var(--gold-bright);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
  }

  .room-gallery {
    display: grid;
    grid-template-columns: 1fr 0.62fr;
    gap: 1rem;
  }

  .room-gallery img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .room-gallery .main-image {
    min-height: 620px;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 1rem;
    margin-top: 5rem;
  }

  .details-panel,
  .practical-panel {
    padding: 1.5rem;
  }

  h2 {
    margin: 0.25rem 0 1.2rem;
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .amenities {
    columns: 2;
    column-gap: 2rem;
  }

  .practical-panel {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .room-hero,
    .details-grid,
    .room-gallery {
      grid-template-columns: 1fr;
    }

    .room-gallery .main-image,
    .room-gallery img {
      min-height: 340px;
    }

    .amenities {
      columns: 1;
    }
  }
</style>

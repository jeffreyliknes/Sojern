---
import OfferCard from "@/components/cards/OfferCard.astro";
import BookingStrip from "@/components/sections/BookingStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import packages from "@/data/packages.json";
---

<BaseLayout title="Angebote" description="Besondere Auszeiten im Romantik Hotel am Brühl.">

  <!-- HERO: Split editorial -->
  <section class="offers-hero">
    <div class="container hero-inner">
      <p class="eyebrow">Angebote</p>
      <h1 class="display hero-heading">Besondere<br />Auszeiten</h1>
      <p class="lede">Feinschmecker, Wanderurlaub, Kulturtrip oder Wohlfühlzeit zu zweit — curated packages ab zwei Nächten. Stornierung bis 3 Tage vor Anreise kostenfrei.</p>
    </div>
    <div class="hero-image">
      <img class="hero-img" src="/images/home/garden.jpg" alt="" />
    </div>
  </section>

  <BookingStrip />

  <section class="container offers-grid">
    {packages.map((offer) => (
      <OfferCard
        name={offer.name}
        description={offer.description_de}
        includes={offer.includes}
        minNights={offer.min_nights}
        href="https://www.hotelambruehl.de/de/buchen.html"
      />
    ))}
  </section>

</BaseLayout>

<style>
  /* ─── HERO ───────────────────────────────────────────── */
  .offers-hero {
    display: grid;
    grid-template-columns: 1fr 0.65fr;
    min-height: 60vh;
    align-items: stretch;
  }

  .hero-inner {
    display: grid;
    align-content: center;
    gap: 1.5rem;
    padding: 6rem 0 5rem;
    max-width: 600px;
  }

  .hero-heading {
    font-size: clamp(4rem, 8vw, 8rem);
    line-height: 0.88;
    color: var(--ink);
  }

  .hero-image {
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ─── OFFERS GRID ─────────────────────────────────────── */
  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 5rem;
    padding-bottom: 5rem;
  }

  @media (max-width: 980px) {
    .offers-hero {
      grid-template-columns: 1fr;
    }

    .hero-image {
      min-height: 320px;
      order: -1;
    }

    .hero-inner {
      padding-top: 4rem;
    }

    .offers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .offers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

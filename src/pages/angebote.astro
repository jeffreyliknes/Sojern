---
import OfferCard from "@/components/cards/OfferCard.astro";
import BookingStrip from "@/components/sections/BookingStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { homeCopy } from "@/data/site";
import packages from "@/data/packages.json";
---

<BaseLayout title="Angebote" description={homeCopy.offersText}>
  <section class="offers-hero container">
    <p class="eyebrow">Angebote</p>
    <h1 class="display">Angebote</h1>
    <p class="lede">
      Ob Feinschmecker, Wander-Urlaub, Kulturtrip oder Wohlfühlzeit zu zweit – unsere besonderen Angebote machen Ihren Urlaub bei uns zu einem besonderen Erlebnis. Stornieren Sie bis 3 Tage vor Anreise kostenfrei.
    </p>
  </section>

  <BookingStrip />

  <section class="container offers-grid">
    {packages.map((offer) => (
      <OfferCard
        name={offer.name}
        description={offer.description_de}
        includes={offer.includes}
        minNights={offer.min_nights}
        href="/buchen"
      />
    ))}
  </section>
</BaseLayout>

<style>
  .offers-hero {
    display: grid;
    gap: 1rem;
    max-width: 980px;
    padding: 5rem 0 4rem;
  }

  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 5rem;
  }

  @media (max-width: 980px) {
    .offers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .offers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

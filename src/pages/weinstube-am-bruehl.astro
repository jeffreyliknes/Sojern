---
import BookingStrip from "@/components/sections/BookingStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { restaurantCopy } from "@/data/site";

const weinstube = restaurantCopy.weinstube;
---

<BaseLayout title={weinstube.title} description={weinstube.body[0]}>

  <!-- HERO: Full-bleed cinematic -->
  <section class="restaurant-hero">
    <img class="hero-img" src="/images/restaurants/weinstube-1.jpg" alt="" />
    <div class="hero-veil"></div>
    <div class="container hero-content">
      <p class="eyebrow">{weinstube.eyebrow}</p>
      <h1 class="display hero-heading">Weinstube<br />am Brühl</h1>
      <p class="hero-lede">Frische Küche. Erlesene Weine.<br />Unvergessliche Abende.</p>
    </div>
  </section>

  <BookingStrip />

  <!-- INTRO + SECOND IMAGE -->
  <section class="container intro-grid">
    <div class="intro-copy">
      {weinstube.body.slice(0, 2).map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <div class="intro-image">
      <img src="/images/restaurants/weinstube-2.jpg" alt="" loading="lazy" />
    </div>
  </section>

  <!-- HOURS: Editorial band -->
  <section class="hours-band">
    <div class="container hours-inner">
      <div>
        <p class="eyebrow">Öffnungszeiten</p>
        <p class="hours-main">Mo – Sa ab 17:30 Uhr</p>
        <p class="hours-note">{weinstube.hours}</p>
      </div>
      <a class="button" href="/anfahrt-kontakt">Tisch reservieren</a>
    </div>
  </section>

  <!-- TEAM: Split editorial -->
  <section class="container team-section">
    <div class="team-grid">
      <img src="/images/restaurants/lorenz.jpg" alt="Sebastian Lorenz" loading="lazy" />
      <div class="team-copy">
        <p class="eyebrow">Das Küchenteam</p>
        <h2>Sebastian<br />Lorenz</h2>
        <p>{weinstube.kitchen}</p>
        <hr />
        <p class="eyebrow">Serviceleitung</p>
        <p>{weinstube.service}</p>
      </div>
    </div>
  </section>

  <!-- MENU CTA -->
  <section class="container menu-cta">
    <div class="panel menu-panel">
      <div class="menu-text">
        <p class="eyebrow">Speisekarte</p>
        <h2>Für jeden Hunger.<br />Für jeden Anlass.</h2>
        <p>Saisonale Gerichte, Kinderkarte und das exklusive Weinstubenmenü mit korrespondierender Weinempfehlung.</p>
      </div>
      <a class="link-arrow" href="/downloads">Aktuelle Speisekarte herunterladen</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ───────────────────────────────────────────── */
  .restaurant-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 7rem;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(20, 13, 8, 0.96) 0%, rgba(20, 13, 8, 0.5) 40%, rgba(20, 13, 8, 0.1) 72%, transparent 100%),
      linear-gradient(to right, rgba(20, 13, 8, 0.55) 0%, transparent 55%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.25rem;
    max-width: 700px;
  }

  .hero-heading {
    font-size: clamp(4rem, 10vw, 9.5rem);
    color: var(--ink);
  }

  .hero-lede {
    color: var(--muted);
    font-size: 1.1rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1.6;
  }

  /* ─── INTRO ───────────────────────────────────────────── */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr minmax(0, 400px);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
    margin-top: 6rem;
  }

  .intro-copy {
    display: grid;
    gap: 1.25rem;
    padding-top: 0.5rem;
  }

  .intro-copy p {
    color: var(--muted);
    line-height: 1.75;
    margin: 0;
    font-size: 1.05rem;
  }

  .intro-image {
    width: min(100%, 400px);
    max-height: 400px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 0;
  }

  .intro-image img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  /* ─── HOURS ───────────────────────────────────────────── */
  .hours-band {
    margin-top: 7rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 3rem 0;
    background: rgba(38, 26, 18, 0.5);
  }

  .hours-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hours-main {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--ink);
    margin: 0.4rem 0 0.5rem;
  }

  .hours-note {
    margin: 0;
    color: var(--soft);
    font-size: 0.9rem;
    max-width: 560px;
    line-height: 1.6;
  }

  /* ─── TEAM ────────────────────────────────────────────── */
  .team-section {
    margin-top: 8rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: minmax(0, 400px) 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .team-grid > img {
    width: 100%;
    max-width: 400px;
    max-height: 400px;
    aspect-ratio: 1;
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--line);
    border-radius: 0;
  }

  .team-copy {
    display: grid;
    gap: 1.2rem;
    align-content: start;
    padding-top: 1rem;
  }

  h2 {
    margin: 0.3rem 0 0.25rem;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.025em;
  }

  .team-copy p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
    font-size: 0.97rem;
  }

  hr {
    width: 100%;
    border: 0;
    border-top: 1px solid var(--line);
    margin: 0.25rem 0;
  }

  /* ─── MENU CTA ────────────────────────────────────────── */
  .menu-cta {
    margin-top: 7rem;
    padding-bottom: 4rem;
  }

  .menu-panel {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    padding: clamp(2rem, 4vw, 3.5rem);
    flex-wrap: wrap;
  }

  .menu-text {
    display: grid;
    gap: 0.75rem;
  }

  .menu-text h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: -0.02em;
  }

  .menu-text p {
    margin: 0;
    color: var(--muted);
    font-size: 0.97rem;
    max-width: 440px;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .intro-grid,
    .team-grid {
      grid-template-columns: 1fr;
    }

    .intro-image img {
      aspect-ratio: 1;
    }

    .hours-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .menu-panel {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 600px) {
    .restaurant-hero {
      padding-bottom: 5rem;
    }
  }
</style>

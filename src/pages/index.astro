---
import OfferCard from "@/components/cards/OfferCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import packages from "@/data/packages.json";

const featuredOffers = packages.slice(0, 3);
const offerImages = [
  "/images/home/offer-gourmet.jpg",
  "/images/home/offer-kultur.jpg",
  "/images/home/offer-auszeit.jpg",
];
const shorten = (text: string, maxWords = 22) => {
  const words = text.trim().split(/\s+/);
  if (words.length <= maxWords) return text;
  return `${words.slice(0, maxWords).join(" ")}…`;
};
---

<BaseLayout title="Romantik Hotel am Brühl" description="Hotel mit Handschrift in Quedlinburg.">

  <!-- HERO: Full-bleed cinematic -->
  <section class="hero">
    <img class="hero-img" src="/images/home/entree.jpg" alt="" />
    <div class="hero-veil"></div>
    <div class="container hero-content">
      <p class="eyebrow hero-eyebrow">Hotel mit Handschrift</p>
      <h1 class="display hero-heading">Romantik Hotel<br />am Brühl</h1>
      <p class="hero-lede">Quedlinburg · Stille · Gastfreundschaft</p>
    </div>
  </section>

  <!-- ROOMS: Editorial full-bleed image grid -->
  <section class="rooms-section">
    <div class="container rooms-header">
      <p class="eyebrow">Unsere Zimmer</p>
      <h2 class="section-title">Räume zum<br />Wohlfühlen</h2>
    </div>
    <div class="rooms-grid">
      <a href="/klassik-zimmer" class="room-card">
        <img src="/images/rooms/klassik-1.jpg" alt="Klassik Zimmer" />
        <div class="room-card-text">
          <span class="eyebrow">Klassik Zimmer</span>
          <h3>Klassik</h3>
          <span class="link-arrow">Entdecken</span>
        </div>
      </a>
      <a href="/suite" class="room-card">
        <img src="/images/rooms/suite-1.jpg" alt="Suite" />
        <div class="room-card-text">
          <span class="eyebrow">Suite</span>
          <h3>Suite</h3>
          <span class="link-arrow">Entdecken</span>
        </div>
      </a>
      <a href="/comfort-zimmer" class="room-card">
        <img src="/images/rooms/comfort-1.jpg" alt="Comfort Zimmer" />
        <div class="room-card-text">
          <span class="eyebrow">Comfort Zimmer</span>
          <h3>Comfort</h3>
          <span class="link-arrow">Entdecken</span>
        </div>
      </a>
      <a href="/apartment" class="room-card">
        <img src="/images/rooms/apartment-1.jpg" alt="Apartment" />
        <div class="room-card-text">
          <span class="eyebrow">Apartment</span>
          <h3>Apartment</h3>
          <span class="link-arrow">Entdecken</span>
        </div>
      </a>
      <a href="/ferienwohnung" class="room-card">
        <img src="/images/rooms/ferienwohnung-1.jpg" alt="Ferienwohnung" />
        <div class="room-card-text">
          <span class="eyebrow">Ferienwohnung</span>
          <h3>Ferienwohnung</h3>
          <span class="link-arrow">Entdecken</span>
        </div>
      </a>
    </div>
    <div class="container rooms-cta">
      <a class="link-arrow" href="/comfort-zimmer">Alle Zimmer ansehen</a>
    </div>
  </section>

  <!-- RESTAURANT: Split cinematic -->
  <section class="container restaurant-section">
    <div class="restaurant-text">
      <p class="eyebrow">Unsere Restaurants</p>
      <h2>Essen.<br />Genießen.<br />Verführen.</h2>
      <p>Frische Küche. Erlesene Weine.<br />Unvergessliche Abende.</p>
      <div class="restaurant-links">
        <a class="link-arrow" href="/weinstube-am-bruehl">Weinstube am Brühl</a>
        <a class="link-arrow" href="/restaurant-le-mariage">Restaurant Le Mariage</a>
      </div>
    </div>
    <div class="restaurant-image">
      <img src="/images/restaurants/weinstube-1.jpg" alt="Weinstube am Brühl" />
    </div>
  </section>

  <!-- EVENTS: Image panel -->
  <section class="container events-section">
    <div class="events-inner panel">
      <div class="events-text">
        <p class="eyebrow">Tagen & Feiern</p>
        <h2>Große<br />Momente</h2>
        <p>Tagungen. Hochzeiten.<br />Feiern mit Handschrift.</p>
        <a class="link-arrow" href="/eventlocation-le-mariage">Le Mariage entdecken</a>
      </div>
      <img src="/images/home/breakfast.jpg" alt="" class="events-image" />
    </div>
  </section>

  <!-- OFFERS: Refined grid -->
  <section class="container offers-section">
    <div class="offers-header">
      <p class="eyebrow">Angebote</p>
      <h2 class="section-title">Besondere<br />Auszeiten</h2>
      <p class="lede">Ausgewählte Pakete für kulinarische, kulturelle und entspannte Tage in Quedlinburg.</p>
    </div>
    <div class="offers-grid">
      {featuredOffers.map((offer, index) => (
        <OfferCard
          name={offer.name}
          description={shorten(offer.description_de)}
          includes={offer.includes}
          minNights={offer.min_nights}
          href="/angebote"
          image={offerImages[index]}
          imageAlt={offer.name}
        />
      ))}
    </div>
    <div class="offers-cta">
      <a class="link-arrow" href="/angebote">Alle Angebote ansehen</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ───────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-h));
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding-bottom: 7rem;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(20, 13, 8, 0.96) 0%, rgba(20, 13, 8, 0.55) 38%, rgba(20, 13, 8, 0.15) 65%, transparent 100%),
      linear-gradient(to right, rgba(20, 13, 8, 0.55) 0%, transparent 55%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.9rem;
    max-width: 700px;
  }

  .hero-eyebrow {
    margin: 0 0 0.1rem;
  }

  .hero-heading {
    margin: 0;
    font-size: clamp(4rem, 9vw, 9.5rem);
    color: var(--ink);
  }

  .hero-lede {
    color: var(--muted);
    font-size: clamp(0.95rem, 1.6vw, 1.2rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    margin: 0;
  }

  /* ─── ROOMS ──────────────────────────────────────────── */
  .rooms-section {
    margin-top: 8rem;
  }

  .rooms-header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .room-card {
    position: relative;
    display: block;
    overflow: hidden;
    width: 100%;
    max-height: 320px;
    aspect-ratio: 1;
    border: 1px solid var(--line);
  }

  .room-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 900ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .room-card:hover img {
    transform: scale(1.04);
  }

  .room-card-text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.25rem 1.2rem;
    background: linear-gradient(to top, rgba(15, 9, 5, 0.94) 0%, rgba(15, 9, 5, 0.4) 55%, transparent 100%);
    display: grid;
    gap: 0.5rem;
  }

  .room-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1;
    color: var(--ink);
  }

  .rooms-cta {
    margin-top: 2rem;
    text-align: right;
  }

  /* ─── RESTAURANT ─────────────────────────────────────── */
  .restaurant-section {
    margin-top: 9rem;
    display: grid;
    grid-template-columns: 1fr minmax(0, 400px);
    align-items: stretch;
    gap: 0;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .restaurant-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.2rem;
    padding: clamp(2rem, 4vw, 3.25rem) clamp(1.75rem, 4vw, 3rem);
    border-right: 1px solid var(--line);
    background: var(--umber-2);
  }

  .restaurant-text h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .restaurant-text > p {
    color: var(--muted);
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .restaurant-links {
    display: grid;
    gap: 0.65rem;
  }

  .restaurant-image {
    width: 100%;
    overflow: hidden;
  }

  .restaurant-image img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 900ms ease;
  }

  .restaurant-section:hover .restaurant-image img {
    transform: scale(1.02);
  }

  /* ─── EVENTS ─────────────────────────────────────────── */
  .events-section {
    margin-top: 8rem;
  }

  .events-inner {
    display: grid;
    grid-template-columns: 1fr minmax(0, 400px);
    align-items: stretch;
    overflow: hidden;
  }

  .events-text {
    display: grid;
    align-content: center;
    gap: 1.25rem;
    padding: clamp(2.5rem, 5vw, 4rem);
  }

  .events-text h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .events-text > p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .events-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  /* ─── OFFERS ─────────────────────────────────────────── */
  .offers-section {
    margin-top: 8rem;
    padding-bottom: 2rem;
  }

  .offers-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 3rem;
    max-width: 480px;
  }

  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .offers-grid :global(.offer-card) {
    border: 0;
    border-radius: 0;
    border-right: 1px solid var(--line);
  }

  .offers-grid :global(.offer-card:last-child) {
    border-right: 0;
  }

  .offers-cta {
    margin-top: 2rem;
    display: flex;
    justify-content: flex-end;
  }

  /* ─── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .rooms-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .room-card {
      aspect-ratio: 1;
    }

    .restaurant-section {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .restaurant-image {
      justify-self: stretch;
    }

    .events-inner {
      grid-template-columns: 1fr;
    }

    .events-image {
      min-height: 280px;
      order: -1;
    }

    .offers-grid {
      grid-template-columns: 1fr;
    }

    .offers-grid :global(.offer-card) {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .offers-grid :global(.offer-card:last-child) {
      border-bottom: 0;
    }
  }

  @media (max-width: 600px) {
    .rooms-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-bottom: 5rem;
    }
  }
</style>

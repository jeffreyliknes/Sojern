---
import FeatureCard from "@/components/cards/FeatureCard.astro";
import OfferCard from "@/components/cards/OfferCard.astro";
import BookingStrip from "@/components/sections/BookingStrip.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { eventsCopy, homeCopy, restaurantCopy, routes } from "@/data/site";
import packages from "@/data/packages.json";
import rooms from "@/data/rooms.json";

const featuredRooms = [
  {
    title: "Klassik",
    href: "/klassik-zimmer",
    image: "/images/rooms/klassik-1.jpg",
    text: rooms.find((room) => room.id === "klassik-double")?.description_de ?? "",
  },
  {
    title: "Suite",
    href: "/suite",
    image: "/images/rooms/suite-1.jpg",
    text: rooms.find((room) => room.id === "suite")?.description_de ?? "",
  },
];

const featuredOffers = packages.slice(0, 3);
---

<BaseLayout title="Romantik Hotel am Brühl" description={homeCopy.welcome}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow">{homeCopy.heroSubheading}</p>
        <h1 class="display">{homeCopy.heroHeading}</h1>
        <p class="lede">{homeCopy.welcome}</p>
        <div class="hero-actions">
          <a class="button" href={routes.booking}>Aufenthalt buchen</a>
          <a class="button secondary" href="/klassik-zimmer">Zimmer entdecken</a>
        </div>
      </div>
      <div class="hero-image panel reveal">
        <img src="/images/home/entree.jpg" alt="" />
        <div class="hero-note">
          <span>Quedlinburg</span>
          <strong>Billungstraße 11</strong>
        </div>
      </div>
    </div>
  </section>

  <BookingStrip />

  <section class="container intro-section">
    <p class="eyebrow">Herzlich Willkommen</p>
    <h2 class="section-title">Romantik Hotel am Brühl</h2>
    <div class="intro-panel panel">
      <img src="/images/home/garden.jpg" alt="" loading="lazy" />
      <p>{homeCopy.welcome}</p>
    </div>
  </section>

  <section class="container content-section">
    <div class="section-heading">
      <p class="eyebrow">Zimmer</p>
      <h2 class="section-title">{homeCopy.roomHeading}</h2>
    </div>
    <div class="card-grid two">
      {featuredRooms.map((room) => (
        <FeatureCard {...room} kicker="Zimmer" />
      ))}
    </div>
  </section>

  <section class="container split-feature">
    <div>
      <p class="eyebrow">Unsere Restaurants</p>
      <h2 class="section-title">Unsere Restaurants</h2>
      <p class="lede">
        Unser engagiertes Küchenteam zaubert mit Hingabe Gerichte á la carte und saisonale Menüs.
      </p>
      <a class="button secondary" href="/weinstube-am-bruehl">Weinstube ansehen</a>
    </div>
    <div class="restaurant-stack">
      <FeatureCard
        title="Weinstube am Brühl"
        kicker="Kulinarische Verführung"
        text="Unser engagiertes Küchenteam zaubert mit Hingabe Gerichte á la carte und saisonale Menüs."
        href="/weinstube-am-bruehl"
        image="/images/restaurants/weinstube-1.jpg"
      />
      <FeatureCard
        title="Restaurant Le Mariage"
        kicker="Wenn es etwas mehr sein darf"
        text={restaurantCopy.leMariageTeaser}
        href="/restaurant-le-mariage"
        image="/images/home/breakfast.jpg"
      />
    </div>
  </section>

  <section class="container events-panel panel">
    <div>
      <p class="eyebrow">Tagen & Feiern</p>
      <h2>Ihre Events</h2>
    </div>
    <p>{eventsCopy.teaser}</p>
    <a class="link-arrow" href="/eventlocation-le-mariage">Le Mariage entdecken</a>
  </section>

  <section class="container content-section">
    <div class="section-heading">
      <p class="eyebrow">Angebote</p>
      <h2 class="section-title">{homeCopy.offersHeading}</h2>
      <p class="lede">{homeCopy.offersText}</p>
    </div>
    <div class="card-grid three">
      {featuredOffers.map((offer) => (
        <OfferCard
          name={offer.name}
          description={offer.description_de}
          includes={offer.includes}
          minNights={offer.min_nights}
          href="/angebote"
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - 86px);
    padding: 5rem 0 7rem;
    display: grid;
    align-items: center;
  }

  .hero-grid,
  .split-feature {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .hero-copy {
    display: grid;
    gap: 1.2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero-image {
    position: relative;
    min-height: 620px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    min-height: 620px;
    object-fit: cover;
  }

  .hero-note {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    display: grid;
    gap: 0.1rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: rgba(15, 16, 13, 0.8);
  }

  .hero-note span {
    color: var(--gold-bright);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .intro-section,
  .content-section,
  .split-feature,
  .events-panel {
    margin-top: 7rem;
  }

  .intro-panel {
    display: grid;
    grid-template-columns: 0.9fr 1fr;
    gap: 2rem;
    align-items: center;
    margin-top: 2rem;
    padding: 1rem 2rem 1rem 1rem;
  }

  .intro-panel img {
    height: 420px;
    width: 100%;
    border-radius: 22px;
    object-fit: cover;
  }

  .intro-panel p {
    color: var(--muted);
    font-size: 1.2rem;
  }

  .section-heading {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .card-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card-grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .restaurant-stack {
    display: grid;
    gap: 1rem;
  }

  .events-panel {
    display: grid;
    grid-template-columns: 0.6fr 1fr auto;
    gap: 2rem;
    align-items: center;
    padding: 2rem;
  }

  .events-panel h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
  }

  .events-panel p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .hero-grid,
    .split-feature,
    .intro-panel,
    .events-panel {
      grid-template-columns: 1fr;
    }

    .hero-image,
    .hero-image img {
      min-height: 420px;
    }

    .card-grid.two,
    .card-grid.three {
      grid-template-columns: 1fr;
    }

    .intro-panel {
      padding: 1rem;
    }
  }
</style>
